# Copy this file to .env and fill in real values.

# Database connection string (SQLAlchemy URL).
#
# Managed Postgres (recommended) — e.g. Neon. Copy the connection string from
# the Neon dashboard and make sure it uses the psycopg2 driver + SSL:
#   postgresql+psycopg2://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
#
# Local Docker Postgres alternative (see docker-compose.yml):
#   postgresql+psycopg2://issuehub:issuehub@localhost:5432/issuehub
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DB?sslmode=require

# JWT settings. Generate a real secret in production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Comma-separated list of origins allowed by CORS.
# Local dev: http://localhost:5173
# Production: your deployed frontend, e.g. https://issuehub.vercel.app
CORS_ORIGINS=http://localhost:5173

# AI provider for the "Enhance Issue Description" feature.
# Only "mock" is implemented; "gemini"/"openai" are left as plug-in points.
AI_PROVIDER=mock
# AI_API_KEY=
